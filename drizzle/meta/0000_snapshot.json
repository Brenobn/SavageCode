  "views": {
    "public.leaderboard_entries": {
      "columns": {},
      "definition": "select \"submissions\".\"id\" as \"submission_id\", \"roast_results\".\"id\" as \"roast_result_id\", \"roast_results\".\"score\" as \"score\", \"submissions\".\"language\" as \"language\", \"submissions\".\"line_count\" as \"line_count\", substring(\"submissions\".\"code\" from 1 for 120) as \"code_preview\", \"roast_results\".\"created_at\" as \"created_at\" from \"roast_results\" inner join \"submissions\" on \"roast_results\".\"submission_id\" = \"submissions\".\"id\" where (\"roast_results\".\"status\" = 'completed' and \"submissions\".\"visibility\" = 'public')",
      "name": "leaderboard_entries",
      "schema": "public",
      "isExisting": false,
      "materialized": false
    }
